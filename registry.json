      "start_cmd": "openclaw gateway start",
      "stop_cmd": "openclaw gateway stop",
      "status_cmd": "openclaw gateway status",
      "restart_cmd": "openclaw gateway restart",
      "health_url": "ws://localhost:18789",
      "log_dir": "~/.openclaw/logs",
      "log_format": "text",
      "config_schema": {
        "common_fields": [
          {
            "key": "gateway.port",
            "label": "gateway port",
            "type": "number",
            "default": 18789,
            "required": true,
            "description": "port for gateway WebSocket RPC",
            "min": 1024,
            "max": 65535,
            "advanced": true
          },
          {
            "key": "gateway.bind",
            "label": "gateway bind address",
            "type": "text",
            "default": "127.0.0.1",
            "required": true,
            "description": "address for gateway to bind to",
            "advanced": true
          },
          {
            "key": "provider",
            "label": "primary LLM provider",
            "type": "select",
            "options": ["vercel-ai-gateway", "openrouter", "anthropic", "openai"],
            "default": "vercel-ai-gateway",
            "required": true,
            "description": "primary LLM provider for agent",
            "group": "llm"
          },
          {
            "key": "model",
            "label": "model",
            "type": "text",
            "default": "vercel-ai-gateway/perplexity/sonar-pro",
            "required": true,
            "description": "model identifier (provider-specific format)",
            "group": "llm",
            "suggestions_key": "provider",
            "suggestions": {
              "vercel-ai-gateway": ["vercel-ai-gateway/perplexity/sonar-pro", "vercel-ai-gateway/anthropic/claude-sonnet-4"],
              "openrouter": ["anthropic/claude-sonnet-4-20250514", "anthropic/claude-opus-4-20250514", "openai/gpt-4.1"],
              "anthropic": ["claude-sonnet-4-20250514", "claude-opus-4-20250514"],
              "openai": ["gpt-4.1", "gpt-4.1-mini", "o3"]
            }
          },
          {
            "key": "tools.profile",
            "label": "tools profile",
            "type": "select",
            "options": ["coding", "research", "assistant", "custom"],
            "default": "coding",
            "required": false,
            "description": "pre-configured toolset profile",
            "advanced": true
          },
          {
            "key": "channels",
            "label": "enabled channels",
            "type": "multiselect",
            "options": ["telegram", "discord", "slack", "whatsapp", "signal", "imessage"],
            "default": ["telegram"],
            "required": false,
            "description": "messaging platforms to enable"
          }
        ],
        "api_key_hint": "set provider-specific API keys (ANTHROPIC_API_KEY, OPENROUTER_API_KEY, etc.) as environment variables or in ~/.openclaw/.env"
      }
    },
    {
