  "frameworks": [
    {
      "id": "zeroclaw",
      "name": "ZeroClaw",
      "description": "Rust-based agent runtime (lean, fast, embedded-friendly)",
      "language": "rust",
      "repository": "https://github.com/zeroclaw-labs/zeroclaw",
      "website": "https://zeroclawlabs.ai",
      "install_method": "cargo",
      "install_cmd": "cargo install --git https://github.com/zeroclaw-labs/zeroclaw zeroclawlabs",
      "requirements": ["rust>=1.70"],
      "min_version": "0.7.0",
      "latest_version": "0.7.3",
      "config_format": "toml",
      "config_path": "~/.zeroclaw/config.toml",
      "config_dir": "~/.zeroclaw",
      "binary_path": "~/.cargo/bin/zeroclaw",
      "adapter_type": "http",
      "default_port": 42617,
      "start_cmd": "zeroclaw daemon",
      "stop_cmd": "zeroclaw service stop",
      "status_cmd": "zeroclaw service status",
      "restart_cmd": "zeroclaw daemon",
      "health_url": "http://localhost:42617/health",
      "log_dir": "~/.zeroclaw/logs",
      "log_format": "text",
      "config_schema": {
        "common_fields": [
          {
            "key": "gateway.port",
            "label": "gateway port",
            "type": "number",
            "default": 42617,
            "required": true,
            "description": "port for gateway HTTP API",
            "min": 1024,
            "max": 65535,
            "advanced": true
          },
          {
            "key": "gateway.host",
            "label": "gateway host",
            "type": "text",
            "default": "127.0.0.1",
            "required": true,
            "description": "host address for gateway to bind to",
            "advanced": true
          },
          {
            "key": "providers.fallback",
            "label": "LLM provider",
            "type": "select",
            "options": ["openrouter", "anthropic", "openai"],
            "default": "openrouter",
            "required": true,
            "description": "which LLM provider to use",
            "group": "llm"
          },
          {
            "key": "providers.models.openrouter.model",
            "label": "model",
            "type": "text",
            "default": "anthropic/claude-sonnet-4.6",
            "required": true,
            "description": "model identifier (provider-specific)",
            "group": "llm",
            "suggestions_key": "providers.fallback",
            "suggestions": {
              "openrouter": ["anthropic/claude-sonnet-4.6", "anthropic/claude-opus-4.6", "moonshotai/kimi-k2.5", "google/gemini-2.5-pro", "openai/gpt-4.1"],
              "anthropic": ["claude-sonnet-4.6", "claude-opus-4.6"],
              "openai": ["gpt-4.1", "gpt-4.1-mini", "o3", "o4-mini"]
            }
          },
          {
            "key": "workspace.path",
            "label": "workspace path",
            "type": "text",
            "default": "~/.zeroclaw/workspace",
            "required": false,
            "description": "directory for agent workspace files",
            "advanced": true
          },
          {
            "key": "memory.backend",
            "label": "memory backend",
            "type": "select",
            "options": ["sqlite", "memory"],
            "default": "sqlite",
            "required": true,
            "description": "storage backend for conversation memory",
            "advanced": true
          }
        ],
        "api_key_hint": "set OPENROUTER_API_KEY, ANTHROPIC_API_KEY, or OPENAI_API_KEY environment variable before starting zeroclaw"
      }
    },
    {
      "id": "openclaw",
